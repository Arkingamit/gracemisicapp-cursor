# ─── Grace Music App — Environment Variables Template ───────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Full MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
# The database name to use within the cluster
MONGODB_DB_NAME=gracemusic

# ── Authentication ────────────────────────────────────────────────────────────
# Strong, random secret for signing JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-min-64-chars

# ── App Setup ────────────────────────────────────────────────────────────────
# Set to "true" after completing the first-run setup wizard.
# The middleware will redirect all traffic to /setup until this is set.
SETUP_COMPLETE=true

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Required if using Google Sign-In
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── OpenAI / AI Chat (optional) ───────────────────────────────────────────────
# Required if using the AI Chat Bot feature
OPENAI_API_KEY=sk-...

# ── App Version (auto-set) ────────────────────────────────────────────────────
# This is automatically injected from package.json by next.config.mjs.
# Do NOT set this manually.
# NEXT_PUBLIC_APP_VERSION=auto
